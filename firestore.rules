rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Company metadata + public signal/price — public read
    match /companies/{ticker} {
      allow read: if true;
      allow write: if false;
    }

    // Snapshots (ML predictions) — must be logged in
    match /companies/{ticker}/snapshots/{date} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Technical indicators — must be logged in
    match /companies/{ticker}/technicals/{date} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Market overview — public read
    match /market_overview/{date} {
      allow read: if true;
      allow write: if false;
    }

    // Corporate events — public read
    match /events/{ticker} {
      allow read: if true;
      allow write: if false;
    }

    // Financial results, dividends, corporate actions — must be logged in
    match /financials/{ticker} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Macro data (CBK rates, inflation) — must be logged in
    match /macro/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // User watchlists — owner only
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
